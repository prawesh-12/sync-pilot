# Auth.js (NextAuth) — Google sign-in
AUTH_SECRET=

# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# PostgreSQL
DATABASE_URL=

# Composio (Gmail integration)
COMPOSIO_API_KEY=
# Auth Config ID created in the Composio dashboard for the Gmail toolkit
COMPOSIO_GMAIL_AUTH_CONFIG_ID=

# Encryption key for token storage (64 char hex)
ENCRYPTION_KEY=

# Groq
GROQ_API_KEY=

# Default model
GROQ_MODEL=openai/gpt-oss-120b

# Signal CLI REST (Docker default)
SIGNAL_CLI_REST_URL=http://localhost:8080

# Cron
CRON_SECRET=

# Shared secret the cron uses to authenticate with the EC2 intake server.
SYNC_SECRET=
# EC2 intake server base URL. When set, the fetch-emails cron enqueues one job
# per account to the worker pool; when blank, it runs accounts inline (local).
INTAKE_SERVER_URL=

# Razorpay billing
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Subscription plan ID created in the Razorpay dashboard (Pro plan)
RAZORPAY_PLAN_ID=
# Secret configured on the Razorpay webhook (used to verify signatures)
RAZORPAY_WEBHOOK_SECRET=

# Observability
# Optional pino log level (default "info").
LOG_LEVEL=
# Better Stack is wired for the web app via a Vercel Log Drain over stdout, so no
# token is needed here. The EC2 worker ships directly — see server/.env.example.