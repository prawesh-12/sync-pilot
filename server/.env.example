# Shared secret that must match SYNC_SECRET in the web app (Vercel).
SYNC_SECRET=

# Redis is local to EC2 and must never be exposed publicly.
REDIS_HOST=localhost
REDIS_PORT=6379

# Express server port.
PORT=3001

# Web app base URL the worker calls to run the agent (e.g. https://app.vercel.app).
WEB_APP_URL=

# BullMQ dashboard Basic-auth credentials. The dashboard at /admin/queues is
# only mounted when BOTH are set.
QUEUE_DASHBOARD_USER=
QUEUE_DASHBOARD_PASSWORD=

# Observability. When BETTERSTACK_SOURCE_TOKEN is set, logs ship to Better Stack
# via the @logtail/pino transport; otherwise they go to stdout.
BETTERSTACK_SOURCE_TOKEN=
# Optional custom ingesting host for Better Stack (EU/self-hosted endpoint).
BETTERSTACK_INGESTING_HOST=
# Optional pino log level (default "info").
LOG_LEVEL=
